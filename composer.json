{
  "name": "velo/router",
  "description": "Router component for Velo framework",
  "type": "library",
  "license": "LGPL-3.0",
  "require": {
    "php": ">=8.5",
    "velo/http": "*",
    "psr/container": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Velo\\Router\\": "src/"
    }
  },
