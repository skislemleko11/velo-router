{
  "name": "skislemleko11/velo-router",
  "description": "Router component for Velo framework",
  "type": "library",
  "license": "LGPL-3.0",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.5",
    "skislemleko11/velo-http": "*",
    "psr/container": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Velo\\Router\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^13"
  },
  "autoload-dev": {
    "psr-4": {
      "Velo\\Router\\Tests\\": "tests/"
    }
  }
}